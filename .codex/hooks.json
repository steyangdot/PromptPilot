{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .codex/hooks/compress_tool_output.py",
            "timeout": 10,
            "statusMessage": "Compressing tool output..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .codex/hooks/optimize_prompt.py",
            "timeout": 30,
            "statusMessage": "Optimizing prompt with SLM..."
          }
        ]
      }
    ]
  }
}
