# Internal project scratch — contain personal email + session-specific
# context; not OSS-appropriate. Stay in the working tree for developer
# reference but don't get tracked. (Match is case-sensitive; .gitignore is
# case-sensitive on Linux/macOS even if Windows filesystem isn't.)
handoff.md
HANDOFF.md
fix_plan.md
FIX_PLAN.md
codexHandoff.txt
SESSION_STATUS.md
SHIP_AS_INSURANCE.md
# Mypy / ruff caches
.mypy_cache/
.ruff_cache/
# Stuck Windows-locked artifact (HANDOFF flagged needs reboot to delete)
chain_results_v2_codex/

# Per-user Claude Code state (default IDE launch config + scheduled-task
# session lock). The hook scripts under .claude/hooks/ DO ship — those
# are project hooks meant for install.
.claude/launch.json
.claude/scheduled_tasks.lock

# Internal dev diaries / raw chain run logs — useful while iterating,
# not useful to OSS users; ~60KB of developer scratch.
Improvements.txt
research/notes/

# Research data (not part of the OSS package)
research/data/
chain_results*/
agentic_test/
agentic_variety/
multirun_results/

# Local-only workspace (notes, defense docs, drafts — never committed)
_workspace/
